# Coverage.py configuration for Snowflake MCP Server Setup
# Author: SE Community

[run]
source = python
omit =
    # Test files themselves
    python/tests/*
    # Python cache
    *__pycache__*
    # Virtual environments
    */venv/*
    */.venv/*
    */env/*
    # Site packages
    */site-packages/*

[report]
# Target: 80%+ coverage
precision = 2
show_missing = True
skip_covered = False

# Exclude lines from coverage
exclude_lines =
    # Standard pragmas
    pragma: no cover

    # Debug-only code
    def __repr__
    if self\.debug

    # Abstract methods
    raise AssertionError
    raise NotImplementedError

    # Type checking blocks
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

    # Main guard
    if __name__ == .__main__.:

[html]
directory = htmlcov

[xml]
output = coverage.xml
