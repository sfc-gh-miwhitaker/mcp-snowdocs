#!/usr/bin/env bash
#===============================================================================
# MCP Snowflake CLI - Unified Command Interface
#
# A single entry point for all MCP server operations.
#
# Usage:
#   ./tools/mcp <command> [options]
#   ./tools/mcp help
#
# Commands:
#   token     Create PAT token for MCP authentication
#   setup     Provision MCP server and apply grants
#   test      Validate SSL and test MCP connection
#   all       Run complete setup (token + setup + test)
#   proxy     Manage local SSE proxy server
#   help      Show this help message
#
# Author: SE Community
#===============================================================================

set -euo pipefail

#-------------------------------------------------------------------------------
# Configuration
#-------------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$SCRIPT_DIR/mac"
PROXY_DIR="$PROJECT_ROOT/proxy"
PIDS_DIR="$PROJECT_ROOT/.pids"

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' NC=''
fi

#-------------------------------------------------------------------------------
# Output Helpers
#-------------------------------------------------------------------------------
banner() {
    echo ""
    echo -e "${CYAN}┌──────────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}$1${NC}"
    echo -e "${CYAN}└──────────────────────────────────────────────────────────────┘${NC}"
    echo ""
}

info()    { echo -e "${BLUE}ℹ${NC}  $1"; }
success() { echo -e "${GREEN}✓${NC}  $1"; }
warn()    { echo -e "${YELLOW}⚠${NC}  $1"; }
error()   { echo -e "${RED}✗${NC}  $1" >&2; }
step()    { echo -e "${DIM}→${NC}  $1"; }

#-------------------------------------------------------------------------------
# Python Environment
#-------------------------------------------------------------------------------
find_python() {
    if [[ -n "${PYTHON_BIN:-}" ]]; then
        echo "$PYTHON_BIN"
    elif command -v python3 &>/dev/null; then
        echo "python3"
    elif command -v python &>/dev/null; then
        echo "python"
    else
        error "Python not found. Please install Python 3.10+"
        exit 1
    fi
}

run_python_cli() {
    local python_bin
    python_bin=$(find_python)
    cd "$PROJECT_ROOT"
    "$python_bin" -m python.cli.main "$@"
}

#-------------------------------------------------------------------------------
# Command: token
#-------------------------------------------------------------------------------
cmd_token() {
    banner "Create PAT Token"
    info "Generating programmatic access token for MCP authentication"
    echo ""
    run_python_cli create-token "$@"
}

#-------------------------------------------------------------------------------
# Command: setup
#-------------------------------------------------------------------------------
cmd_setup() {
    banner "Setup MCP Server"
    info "Provisioning MCP server and applying least-privilege grants"
    echo ""
    run_python_cli setup-mcp "$@"
}

#-------------------------------------------------------------------------------
# Command: test
#-------------------------------------------------------------------------------
cmd_test() {
    banner "Test MCP Connection"
    info "Validating SSL certificate and testing MCP endpoint"
    echo ""
    run_python_cli test-connection "$@"
}

#-------------------------------------------------------------------------------
# Command: all (master workflow)
#-------------------------------------------------------------------------------
cmd_all() {
    banner "Complete MCP Setup"
    info "Running full setup workflow: token → setup → test"
    echo ""
    run_python_cli master "$@"
}

#-------------------------------------------------------------------------------
# Command: proxy
#-------------------------------------------------------------------------------
cmd_proxy() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        start)  cmd_proxy_start "$@" ;;
        stop)   cmd_proxy_stop "$@" ;;
        status) cmd_proxy_status "$@" ;;
        logs)   cmd_proxy_logs "$@" ;;
        *)      cmd_proxy_help ;;
    esac
}

cmd_proxy_help() {
    echo ""
    echo -e "${BOLD}Proxy Commands${NC}"
    echo ""
    echo "  ${CYAN}mcp proxy start${NC}   Start the local SSE proxy server"
    echo "  ${CYAN}mcp proxy stop${NC}    Stop the proxy server"
    echo "  ${CYAN}mcp proxy status${NC}  Check if proxy is running"
    echo "  ${CYAN}mcp proxy logs${NC}    View proxy server logs"
    echo ""
    echo "The proxy fixes SSE streaming errors with Snowflake MCP server."
    echo "See docs/05-PROXY-SETUP.md for configuration details."
    echo ""
}

cmd_proxy_start() {
    banner "Start MCP Proxy"

    # Check Node.js
    if ! command -v node &>/dev/null; then
        error "Node.js not found. Install from https://nodejs.org/"
        exit 1
    fi

    local node_version
    node_version=$(node -v | cut -d'v' -f2 | cut -d'.' -f1)
    if [[ "$node_version" -lt 18 ]]; then
        error "Node.js 18+ required (found v$node_version)"
        exit 1
    fi

    # Check config
    if [[ ! -f "$PROXY_DIR/config.js" ]]; then
        warn "proxy/config.js not found"
        echo ""
        info "Create it by copying the example:"
        echo "    cp proxy/config.example.js proxy/config.js"
        echo "    # Edit with your MCP URL and PAT token"
        exit 1
    fi

    # Install deps if needed
    if [[ ! -d "$PROXY_DIR/node_modules" ]]; then
        step "Installing npm dependencies..."
        (cd "$PROXY_DIR" && npm install --silent)
        success "Dependencies installed"
    fi

    # Get port from config
    local port
    port=$(grep -o 'proxyPort:[[:space:]]*[0-9]*' "$PROXY_DIR/config.js" 2>/dev/null | grep -o '[0-9]*' || echo "3456")

    # Check port availability
    if lsof -Pi ":$port" -sTCP:LISTEN -t &>/dev/null; then
        warn "Port $port already in use"
        info "Run 'mcp proxy status' to check what's running"
        exit 1
    fi

    # Background mode check
    local background=false
    for arg in "$@"; do
        [[ "$arg" == "--bg" || "$arg" == "--background" ]] && background=true
    done

    mkdir -p "$PIDS_DIR"

    if [[ "$background" == true ]]; then
        step "Starting proxy in background..."
        (cd "$PROXY_DIR" && nohup node server.js > proxy.log 2>&1 &
         echo $! > "$PIDS_DIR/proxy.pid")
        sleep 2

        local pid
        pid=$(cat "$PIDS_DIR/proxy.pid" 2>/dev/null || echo "")
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            success "Proxy started (PID: $pid)"
            echo ""
            info "Configure your IDE to use: ${BOLD}http://127.0.0.1:$port/mcp${NC}"
            info "Stop with: ${BOLD}./tools/mcp proxy stop${NC}"
        else
            error "Proxy failed to start. Check: cat proxy/proxy.log"
            exit 1
        fi
    else
        info "Starting proxy in foreground (Ctrl+C to stop)..."
        echo ""
        (cd "$PROXY_DIR" && exec node server.js)
    fi
}

cmd_proxy_stop() {
    banner "Stop MCP Proxy"

    local stopped=false
    local pid_file="$PIDS_DIR/proxy.pid"

    # Try PID file first
    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            step "Stopping proxy (PID: $pid)..."
            kill "$pid" 2>/dev/null || true
            sleep 1
            kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
            success "Proxy stopped"
            stopped=true
        fi
        rm -f "$pid_file"
    fi

    # Also check by port
    local port
    port=$(grep -o 'proxyPort:[[:space:]]*[0-9]*' "$PROXY_DIR/config.js" 2>/dev/null | grep -o '[0-9]*' || echo "3456")

    if lsof -Pi ":$port" -sTCP:LISTEN -t &>/dev/null; then
        local port_pid
        port_pid=$(lsof -Pi ":$port" -sTCP:LISTEN -t 2>/dev/null | head -1)
        step "Stopping process on port $port (PID: $port_pid)..."
        kill "$port_pid" 2>/dev/null || true
        success "Process stopped"
        stopped=true
    fi

    if [[ "$stopped" == false ]]; then
        info "No proxy server found running"
    fi
}

cmd_proxy_status() {
    banner "Proxy Status"

    local port
    port=$(grep -o 'proxyPort:[[:space:]]*[0-9]*' "$PROXY_DIR/config.js" 2>/dev/null | grep -o '[0-9]*' || echo "3456")

    local running=false
    local pid=""

    if [[ -f "$PIDS_DIR/proxy.pid" ]]; then
        pid=$(cat "$PIDS_DIR/proxy.pid")
        kill -0 "$pid" 2>/dev/null && running=true
    fi

    if lsof -Pi ":$port" -sTCP:LISTEN -t &>/dev/null; then
        running=true
        [[ -z "$pid" ]] && pid=$(lsof -Pi ":$port" -sTCP:LISTEN -t 2>/dev/null | head -1)
    fi

    if [[ "$running" == true ]]; then
        echo -e "  Status:   ${GREEN}● Running${NC}"
        echo -e "  PID:      $pid"
        echo -e "  Port:     $port"
        echo ""
        echo -e "  Endpoints:"
        echo -e "    ${CYAN}http://127.0.0.1:$port/mcp${NC}     MCP proxy"
        echo -e "    ${CYAN}http://127.0.0.1:$port/health${NC}  Health check"
        echo ""

        # Health check
        if command -v curl &>/dev/null; then
            local status
            status=$(curl -s -o /dev/null -w "%{http_code}" "http://127.0.0.1:$port/health" 2>/dev/null || echo "000")
            if [[ "$status" == "200" ]]; then
                success "Health check: OK"
            else
                warn "Health check: HTTP $status"
            fi
        fi
    else
        echo -e "  Status:   ${RED}● Stopped${NC}"
        echo ""
        info "Start with: ./tools/mcp proxy start"
    fi
}

cmd_proxy_logs() {
    local log_file="$PROXY_DIR/proxy.log"
    if [[ -f "$log_file" ]]; then
        tail -f "$log_file"
    else
        info "No log file found at $log_file"
    fi
}

#-------------------------------------------------------------------------------
# Command: help
#-------------------------------------------------------------------------------
cmd_help() {
    echo ""
    echo -e "${BOLD}MCP Snowflake CLI${NC}"
    echo -e "${DIM}Unified command interface for MCP server operations${NC}"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "    ./tools/mcp <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo ""
    echo -e "  ${CYAN}token${NC}              Create PAT token for MCP authentication"
    echo -e "                     Options: --profile <name> --dry-run --verbose"
    echo ""
    echo -e "  ${CYAN}setup${NC}              Provision MCP server and apply grants"
    echo -e "                     Options: --profile <name> --dry-run --verbose"
    echo ""
    echo -e "  ${CYAN}test${NC}               Validate SSL and test MCP connection"
    echo -e "                     Options: --url <url> --hostname <host> --token <token>"
    echo ""
    echo -e "  ${CYAN}all${NC}                Run complete setup (token + setup + test)"
    echo -e "                     Options: --profile <name> --url <url> --skip-test"
    echo ""
    echo -e "  ${CYAN}proxy${NC}              Manage local SSE proxy server"
    echo -e "                     Subcommands: start, stop, status, logs"
    echo ""
    echo -e "  ${CYAN}help${NC}               Show this help message"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo ""
    echo "    # Create token using default profile"
    echo "    ./tools/mcp token"
    echo ""
    echo "    # Setup with specific profile"
    echo "    ./tools/mcp setup --profile myprofile"
    echo ""
    echo "    # Test connection"
    echo "    ./tools/mcp test --url https://org-acct.snowflakecomputing.com/api/v2/cortex/mcp/..."
    echo ""
    echo "    # Start proxy in background"
    echo "    ./tools/mcp proxy start --bg"
    echo ""
    echo -e "${BOLD}DOCUMENTATION${NC}"
    echo ""
    echo "    docs/01-SETUP.md         Prerequisites and environment setup"
    echo "    docs/05-PROXY-SETUP.md   SSE proxy configuration"
    echo ""
}

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------
main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        token|create-token)   cmd_token "$@" ;;
        setup|setup-mcp)      cmd_setup "$@" ;;
        test|test-connection) cmd_test "$@" ;;
        all|master)           cmd_all "$@" ;;
        proxy)                cmd_proxy "$@" ;;
        help|--help|-h)       cmd_help ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"

